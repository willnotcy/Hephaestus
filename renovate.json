{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended"
  ],

  "platformAutomerge": true,

  "flux": {
    "managerFilePatterns": [
      "/cluster/.+\\.ya?ml$/"
    ]
  },

  "ignorePaths": [
    "apps/archive/**"
  ],

  "helm-values": {
    "managerFilePatterns": [
      "/cluster/.+\\.ya?ml$/",
      "/apps/.+\\.ya?ml$/",
      "/infrastructure/.+\\.ya?ml$/"
    ]
  },

  "kubernetes": {
    "managerFilePatterns": [
      "/cluster/.+\\.ya?ml$/",
      "/apps/.+\\.ya?ml$/",
      "/infrastructure/.+\\.ya?ml$/"
    ]
  },

  "customManagers": [
    {
      "customType": "regex",
      "description": "Match Helm values for non-standard yamls",
      "managerFilePatterns": [
        "/infrastructure/.+\\.ya?ml$/"
      ],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "repository:\\s?\"?(?<depName>[^\\s\"]*)\"?\\s*?tag:\\s?\"?(?<currentValue>[^\\s\"]*)\"?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Match Helm Releases for helm charts",
      "managerFilePatterns": [
        "/apps/.+\\.ya?ml$/",
        "/infrastructure/.+\\.ya?ml$/"
      ],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "chart:\\s?\"?(?<depName>[^\\s\"]*)\"?\\s*?version:\\s?\"?(?<currentValue>[^\\s\"]*)\"?"
      ],
      "datasourceTemplate": "helm"
    }
  ],

  "packageRules": [
    {
      "description": "Auto-merge all safe updates (default behavior)",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },

    {
      "description": "NEVER automerge critical services",
      "automerge": false,
      "matchPackageNames": [
        "/home-assistant/",
        "/homeassistant/",
        "/immich/",
        "/postgres/",
        "/paperless/",
        "/tinyauth/",
        "/pocket-id/",
        "/volsync/",
        "/tika/",
        "/redis/",
        "/gotenberg/",
        "/fluxcd/",
        "/frigate/",
        "/omada-controller/",
        "/flux-system/"
      ]
    },

    {
      "description": "Handle Flux Helm repo for app-template",
      "matchDatasources": ["helm"],
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["app-template"],
      "registryUrls": [
        "https://bjw-s.github.io/helm-charts/"
      ]
    }
  ]
}
