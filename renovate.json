{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "platformAutomerge": true,
  "flux": {
    "managerFilePatterns": [
      "/cluster/.+\\.ya?ml$/"
    ]
  },
  "ignorePaths": [
    "apps/archive/**"
  ],
  "helm-values": {
    "managerFilePatterns": [
      "/cluster/.+\\.ya?ml$/",
      "/apps/.+\\.ya?ml$/",
      "/infrastructure/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/cluster/.+\\.ya?ml$/",
      "/apps/.+\\.ya?ml$/",
      "/infrastructure/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Match Helm values for non-standard yamls",
      "managerFilePatterns": [
        "/infrastructure/.+\\.ya?ml$/"
      ],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "repository:\\s?\"?(?<depName>[^\\s\"]*)\"?\\s*?tag:\\s?\"?(?<currentValue>[^\\s\"]*)\"?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Match Helm Releases for helm charts",
      "managerFilePatterns": [
        "/apps/.+\\.ya?ml$/",
        "/infrastructure/.+\\.ya?ml$/"
      ],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "chart:\\s?\"?(?<depName>[^\\s\"]*)\"?\\s*?version:\\s?\"?(?<currentValue>[^\\s\"]*)\"?"
      ],
      "datasourceTemplate": "helm"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "helm"
      ],
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "app-template"
      ],
      "registryUrls": [
        "https://bjw-s.github.io/helm-charts/"
      ]
    },
    {
      "description": "Auto-merge non-major updates for minor/patch cleanliness",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Override: Strictly forbid automerge for defined critical apps and components",
      "matchPackageNames": [
        "ghcr.io/home-operations/home-assistant",
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/postgres",
        "ghcr.io/immich-app/immich-machine-learning",
        "ghcr.io/paperless-ngx/paperless-ngx",
        "ghcr.io/steveiliop56/tinyauth",
        "ghcr.io/pocket-id/pocket-id",
        "ghcr.io/home-operations/charts-mirror/volsync"
      ],
      "matchPackagePatterns": [
        "^ghcr\\.io/fluxcd/",
        "fluxcd",
        "flux-system"
      ],
      "matchManagers": ["flux"],
      "automerge": false
    }
  ]
}
